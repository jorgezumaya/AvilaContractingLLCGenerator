# Auth0 credentials for Avila Contracting LLC Generator
# Copy this to .env and fill in your values.
# These map 1-to-1 with src/environments/environment*.ts
#
# Find these in Auth0 Dashboard → Applications → AvilaContractingLLC → Settings
# DO NOT commit .env or the real environment.ts files.
# Add these as GitHub Secrets (Settings → Secrets → Actions) for CI/CD.

AUTH0_DOMAIN=YOUR_TENANT.us.auth0.com
AUTH0_CLIENT_ID=YOUR_CLIENT_ID
